{
  "name": "@ideative/simplutils",
  "version": "0.0.2",
  "description": "SimplUtils - Simplified utilities",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./arrays": {
      "types": "./dist/arrays.d.ts",
      "import": "./dist/arrays.js",
      "default": "./dist/arrays.js"
    },
    "./objects": {
      "types": "./dist/objects.d.ts",
      "import": "./dist/objects.js",
      "default": "./dist/objects.js"
    },
    "./types/zod": {
      "types": "./dist/types/zod.d.ts",
      "import": "./dist/types/zod.js",
      "default": "./dist/types/zod.js"
    },
    "./views": {
      "types": "./dist/views/index.d.ts",
      "import": "./dist/views/index.js",
      "default": "./dist/views/index.js"
    },
    "./resource": {
      "types": "./dist/resource/index.d.ts",
      "import": "./dist/resource/index.js",
      "default": "./dist/resource/index.js"
    },
    "./countries": {
      "types": "./dist/countries/index.d.ts",
      "import": "./dist/countries/index.js",
      "default": "./dist/countries/index.js"
    },
    "./enums": {
      "types": "./dist/enums/index.d.ts",
      "import": "./dist/enums/index.js",
      "default": "./dist/enums/index.js"
    },
    "./strings": {
      "types": "./dist/strings/index.d.ts",
      "import": "./dist/strings/index.js",
      "default": "./dist/strings/index.js"
    },
    "./throttle": {
      "types": "./dist/throttle/index.d.ts",
      "import": "./dist/throttle/index.js",
      "default": "./dist/throttle/index.js"
    },
    "./try": {
      "types": "./dist/try/index.d.ts",
      "import": "./dist/try/index.js",
      "default": "./dist/try/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "default": "./dist/types/index.js"
    },
    "./zustand": {
      "types": "./dist/zustand/index.d.ts",
      "import": "./dist/zustand/index.js",
      "default": "./dist/zustand/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "jest",
    "docs": "pnpm --filter @simplutils/docs-web dev",
    "docs:build": "pnpm --filter @simplutils/docs docs:build && pnpm --filter @simplutils/docs-web build",
    "prepublishOnly": "pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ideativedigital/simplutils"
  },
  "author": {
    "name": "Adrien Cominotto",
    "email": "adrien.cominotto@gmail.com",
    "url": "https://github.com/acominotto"
  },
  "license": "ISC",
  "peerDependencies": {
    "zustand": "^5.0.11",
    "zod": ">=4.3.6",
    "zod-ky": "0.0.3"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "lodash.isequal": "^4.5.0"
  },
  "engines": {
    "node": ">=22.10.1",
    "pnpm": ">=10.26.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/lodash.isequal": "^4.5.8",
    "@types/node": "^22.10.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2",
    "zustand": "^5.0.11"
  },
  "keywords": []
}
